{% extends 'base.html.twig' %}

{% block title %}Catégories{% endblock %}

{% block body %}

<div class="d-flex justify-content-between align-items-center mb-4">

    <h2>Catégories</h2>

    <a href="{{ path('app_categorie_recette_new') }}" class="btn btn-main">
        + Nouvelle catégorie
    </a>

</div>

<div class="row g-3">

    {% for categorie in categorie_recettes %}

        <div class="col-md-4">

            <div class="card recipe-card p-3">

                <h5>{{ categorie.nom }}</h5>

                <div class="mt-3 d-flex gap-2">

                    <a href="{{ path('app_categorie_recette_show', {'id': categorie.id}) }}" class="btn btn-dark btn-sm">
                        Voir
                    </a>

                    <a href="{{ path('app_categorie_recette_edit', {'id': categorie.id}) }}" class="btn btn-warning btn-sm">
                        Edit
                    </a>

                </div>

            </div>

        </div>

    {% else %}

        <p>Aucune catégorie</p>

    {% endfor %}

</div>

{% endblock %}