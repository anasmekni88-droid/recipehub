{% extends 'base.html.twig' %}

{% block title %}Catégories{% endblock %}

{% block body %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="section-title mb-1">
            <i class="bi bi-tags"></i>
            Catégories
        </h2>
        <p class="text-muted">Gérez les catégories de recettes.</p>
    </div>
    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_categorie_recette_new') }}" class="btn btn-main">
            <i class="bi bi-plus-circle"></i>
            Nouvelle catégorie
        </a>
    {% endif %}
</div>

<div class="row g-4">

    {% for categorie in categorie_recettes %}

        <div class="col-md-6 col-lg-4">

            <div class="card recipe-card h-100 p-4">

                <div class="text-center mb-3">
                    <span style="font-size: 3rem;">{{ categorie.icone ?: '📂' }}</span>
                </div>

                <h5 class="text-center fw-bold">{{ categorie.nom }}</h5>

                {% if categorie.description %}
                    <p class="text-muted small text-center mb-3">
                        {{ categorie.description }}
                    </p>
                {% endif %}

                <div class="text-center mb-3">
                    <span class="badge bg-dark">
                        {{ categorie.recettes|length }} recette{% if categorie.recettes|length > 1 %}s{% endif %}
                    </span>
                </div>

                <div class="mt-auto d-flex justify-content-center gap-2">
                    <a href="{{ path('app_categorie_recette_show', {'id': categorie.id}) }}" class="btn btn-dark btn-sm">
                        Voir
                    </a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_categorie_recette_edit', {'id': categorie.id}) }}" class="btn btn-warning btn-sm">
                            <i class="bi bi-pencil"></i>
                        </a>
                    {% endif %}
                </div>

            </div>

        </div>

    {% else %}

        <div class="col-12">
            <div class="alert alert-info text-center p-5">
                <h4><i class="bi bi-inbox"></i> Aucune catégorie</h4>
                <p>Commencez par créer une catégorie.</p>
            </div>
        </div>

    {% endfor %}

</div>

{% endblock %}
