{% extends 'base.html.twig' %}

{% block title %}Gestion des utilisateurs{% endblock %}

{% block body %}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h2 class="section-title mb-1">
            <i class="bi bi-people-fill"></i>
            Gestion des utilisateurs
        </h2>
        <p class="text-muted">Liste de tous les utilisateurs inscrits.</p>
    </div>
</div>

<div class="card shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Pseudo</th>
                        <th>Email</th>
                        <th>Rôles</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                        <tr>
                            <td class="fw-semibold">{{ user.pseudo }}</td>
                            <td>{{ user.email }}</td>
                            <td>
                                {% for role in user.roles %}
                                    <span class="badge {% if role == 'ROLE_ADMIN' %}bg-danger{% elseif role == 'ROLE_CUISINIER' %}bg-success{% else %}bg-secondary{% endif %} me-1">
                                        {{ role }}
                                    </span>
                                {% endfor %}
                            </td>
                            <td>
                                {% if user != app.user %}
                                    <form method="post"
                                          action="{{ path('app_admin_user_delete', {'id': user.id}) }}"
                                          onsubmit="return confirmAction(event, 'Supprimer l\'utilisateur ?', 'Êtes-vous sûr de vouloir supprimer cet utilisateur ? Cette action est irréversible.');"
                                          style="display:inline-block">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete-user-' ~ user.id) }}">
                                        <button class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i> Supprimer
                                        </button>
                                    </form>
                                {% else %}
                                    <span class="text-muted small"><i class="bi bi-shield-check"></i> Vous</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-4">Aucun utilisateur.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% endblock %}
