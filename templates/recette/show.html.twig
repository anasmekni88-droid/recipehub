{% extends 'base.html.twig' %}

{% block body %}

    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="mb-4">
                <img
                    src="{{ recette.imageName ? asset('uploads/recettes/' ~ recette.imageName) : 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?q=80&w=1000' }}"
                    class="img-fluid rounded-4 w-100"
                    alt="{{ recette.titre }}"
                    style="height: 400px; object-fit: cover;"
                >
            </div>

            <h1 class="fw-bold mb-4">{{ recette.titre }}</h1>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <p class="mb-0 text-muted">Préparation</p>
                    <strong>{{ recette.tempsPreparation }} min</strong>
                </div>
                <div class="col-md-4">
                    <p class="mb-0 text-muted">Cuisson</p>
                    <strong>{{ recette.tempsCuisson }} min</strong>
                </div>
                <div class="col-md-4">
                    <p class="mb-0 text-muted">Personnes</p>
                    <strong>{{ recette.nbPersonnes }}</strong>
                </div>
            </div>

            <p class="text-muted mb-4">{{ recette.description }}</p>

            <h3 class="fw-bold mb-3">
                <i class="bi bi-list-check"></i>
                Instructions
            </h3>

            <div class="bg-light p-4 rounded-4 mb-4">
                {{ recette.instructions|nl2br }}
            </div>

            <div class="d-flex gap-3 mt-4">
                <form method="post" action="{{ path('app_favorite_add', {'id': recette.id}) }}" style="display:inline-block">
                    <button class="btn btn-outline-warning">
                        <i class="bi bi-star"></i> Ajouter aux favoris
                    </button>
                </form>

                <a href="{{ path('app_recette_edit', {'id': recette.id}) }}" class="btn btn-warning">
                    <i class="bi bi-pencil-square"></i>
                    Modifier
                </a>

                <a href="{{ path('app_recette_index') }}" class="btn btn-dark">
                    <i class="bi bi-arrow-left"></i>
                    Retour
                </a>
            </div>

        </div>
    </div>

{% endblock %}