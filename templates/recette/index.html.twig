{% extends 'base.html.twig' %}

{% block title %}Nos Recettes{% endblock %}

{% block body %}

<div class="d-flex justify-content-between align-items-center mb-5">

    <div>
        <h2 class="section-title mb-1">
            <i class="bi bi-journal-richtext"></i>
            Nos Recettes
        </h2>

        <p class="text-muted">
            Découvrez les meilleures recettes de notre communauté.
        </p>
    </div>

    <a href="{{ path('app_recette_new') }}" class="btn btn-main">
        <i class="bi bi-plus-circle"></i>
        Ajouter une recette
    </a>

</div>

<div class="row g-4">

    {% for recette in recettes %}

        <div class="col-md-6 col-lg-4">

            <div class="card recipe-card h-100">

                <img
                    src="{{ recette.imageName ? asset('uploads/recettes/' ~ recette.imageName) : 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?q=80&w=1000' }}"
                    class="card-img-top"
                    alt="{{ recette.titre }}"
                    style="height: 220px; object-fit: cover;"
                >

                <div class="card-body d-flex flex-column">

                    <div class="d-flex justify-content-between align-items-center mb-2">

                        <span class="badge badge-difficulty">
                            {{ recette.difficulte }}
                        </span>

                        <small class="recipe-meta">
                            <i class="bi bi-clock"></i>
                            {{ recette.tempsPreparation }} min
                        </small>

                    </div>

                    <h5 class="recipe-title">
                        {{ recette.titre }}
                    </h5>

                    <p class="text-muted small">
                        {{ recette.description|slice(0, 100) }}...
                    </p>

                    <div class="mt-auto">

                        <div class="d-flex justify-content-between align-items-center">

                            <small class="recipe-meta">
                                <i class="bi bi-people"></i>
                                {{ recette.nbPersonnes }} personnes
                            </small>

                            <a href="{{ path('app_recette_show', {'id': recette.id}) }}"
                               class="btn btn-sm btn-dark">
                                Voir plus
                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    {% else %}

        <div class="col-12">

            <div class="alert alert-warning text-center p-5">

                <h4>Aucune recette trouvée</h4>

                <p>
                    Commencez par ajouter votre première recette.
                </p>

            </div>

        </div>

    {% endfor %}

</div>

{% endblock %}