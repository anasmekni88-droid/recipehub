{% extends 'base.html.twig' %}

{% block title %}Nos Recettes{% endblock %}

{% block body %}

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h2 class="section-title mb-1">
            <i class="bi bi-journal-richtext"></i>
            Nos Recettes
        </h2>
        <p class="text-muted">
            Découvrez les meilleures recettes de notre communauté.
        </p>
    </div>
    {% if is_granted('ROLE_CUISINIER') %}
        <a href="{{ path('app_recette_new') }}" class="btn btn-main">
            <i class="bi bi-plus-circle"></i>
            Ajouter une recette
        </a>
    {% endif %}
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card bg-primary text-white h-100">
            <div class="card-body text-center">
                <h5 class="card-title"><i class="bi bi-book"></i> Recettes publiées</h5>
                <p class="display-6 mb-0">{{ stats.total_publiees }}</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white h-100">
            <div class="card-body text-center">
                <h5 class="card-title"><i class="bi bi-tags"></i> Catégories</h5>
                <p class="display-6 mb-0">{{ stats.par_categorie|length }}</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-info text-white h-100">
            <div class="card-body text-center">
                <h5 class="card-title"><i class="bi bi-egg"></i> Moy. ingrédients</h5>
                <p class="display-6 mb-0">{{ stats.moyenne_ingredients }}</p>
            </div>
        </div>
    </div>
</div>

{% if stats.par_categorie is not empty %}
<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title"><i class="bi bi-pie-chart"></i> Répartition par catégorie</h5>
        <div class="row mt-3">
            {% for categorie, count in stats.par_categorie %}
                <div class="col-md-4 mb-2">
                    <div class="d-flex justify-content-between">
                        <span>{{ categorie }}</span>
                        <span class="badge bg-secondary rounded-pill">{{ count }}</span>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endif %}

<form method="get" class="row g-2 mb-4 p-3 bg-white rounded shadow-sm">
    <div class="col-md-4">
        <input type="text" name="titre" class="form-control" placeholder="Rechercher par titre..." value="{{ app.request.query.get('titre') }}">
    </div>
    <div class="col-md-3">
        <select name="categorie" class="form-select">
            <option value="">Toutes les catégories</option>
            {% for cat in categories %}
                <option value="{{ cat.id }}" {{ app.request.query.get('categorie') == cat.id ? 'selected' : '' }}>{{ cat.nom }}</option>
            {% endfor %}
        </select>
    </div>
    <div class="col-md-2">
        <select name="difficulte" class="form-select">
            <option value="">Difficulté</option>
            <option value="Facile" {{ app.request.query.get('difficulte') == 'Facile' ? 'selected' : '' }}>Facile</option>
            <option value="Moyen" {{ app.request.query.get('difficulte') == 'Moyen' ? 'selected' : '' }}>Moyen</option>
            <option value="Difficile" {{ app.request.query.get('difficulte') == 'Difficile' ? 'selected' : '' }}>Difficile</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="tag" class="form-select">
            <option value="">Tous les tags</option>
            {% for t in tags %}
                <option value="{{ t.id }}" {{ app.request.query.get('tag') == t.id ? 'selected' : '' }}>{{ t.nom }}</option>
            {% endfor %}
        </select>
    </div>
    <div class="col-md-1 d-flex gap-1">
        <button type="submit" class="btn btn-main w-100"><i class="bi bi-search"></i></button>
        <a href="{{ path(app.request.attributes.get('_route')) }}" class="btn btn-outline-secondary w-100"><i class="bi bi-x-lg"></i></a>
    </div>
</form>

<div class="row g-4">
    {% for recette in recettes %}
        <div class="col-md-6 col-lg-4">
            <div class="card recipe-card h-100">
                {% if recette.imageName %}
                    <img src="{{ asset('uploads/recettes/' ~ recette.imageName) }}"
                         class="card-img-top"
                         alt="{{ recette.titre }}"
                         style="height: 220px; object-fit: cover;">
                {% else %}
                    <div class="d-flex align-items-center justify-content-center bg-light"
                         style="height: 220px; font-size: 4rem;">
                        {{ recette.categorie.icone ?: '🍽' }}
                    </div>
                {% endif %}

                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="d-flex gap-1 flex-wrap">
                            <span class="badge badge-difficulty">{{ difficulty_stars(recette.difficulte) }}</span>
                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Publiée</span>
                        </div>
                        <small class="recipe-meta">
                            <i class="bi bi-clock"></i> Total: {{ (recette.tempsPreparation + (recette.tempsCuisson ?? 0))|cooking_time_format }}
                        </small>
                    </div>

                    <h5 class="recipe-title">{{ recette.titre }}</h5>

                    <div class="mb-2">
                        <small class="text-muted">
                            {{ recette.categorie.icone ?: '📂' }} {{ recette.categorie.nom }}
                        </small>
                    </div>

                    {% if recette.tags is not empty %}
                        <div class="mb-2 d-flex flex-wrap gap-1">
                            {% for tag in recette.tags %}
                                <span class="badge" style="background-color: {{ tag.couleur }}; color: #fff;">
                                    {{ tag.nom }}
                                </span>
                            {% endfor %}
                        </div>
                    {% endif %}

                    <p class="text-muted small">
                        {{ recette.description|slice(0, 100) }}...
                    </p>

                    <div class="mt-auto">
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="recipe-meta">
                                <i class="bi bi-people"></i> {{ recette.nbPersonnes }} personnes
                            </small>
                            <small class="recipe-meta">
                                <i class="bi bi-clock-history"></i> {{ recette.dateCreation|time_ago }}
                            </small>
                            <div class="d-flex gap-2">
                                <a href="{{ path('app_recette_show', {'id': recette.id}) }}"
                                   class="btn btn-sm btn-dark">Voir plus</a>
                                {% if is_granted('edit', recette) %}
                                    <a href="{{ path('app_recette_edit', {'id': recette.id}) }}" class="btn btn-sm btn-warning" title="Modifier">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                {% endif %}
                                {% if is_granted('delete', recette) %}
                                    <form method="post" action="{{ path('app_recette_delete', {'id': recette.id}) }}" style="display:inline" onsubmit="return confirmDelete(event, '{{ recette.titre }}')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ recette.id) }}">
                                        <button class="btn btn-sm btn-outline-danger" title="Supprimer">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12">
            <div class="alert alert-warning text-center p-5">
                <h4>Aucune recette trouvée</h4>
                <p>Commencez par ajouter votre première recette.</p>
            </div>
        </div>
    {% endfor %}
</div>

{{ knp_pagination_render(recettes) }}

{% endblock %}
