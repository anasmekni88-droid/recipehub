<form method="post"
      action="{{ path('app_recette_delete', {'id': recette.id}) }}"
      onsubmit="return confirmAction(event, 'Supprimer la recette ?', 'Êtes-vous sûr de vouloir supprimer cette recette ? Cette action est irréversible.');">

    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ recette.id) }}">

    <button class="btn btn-danger mt-3">
        <i class="bi bi-trash"></i>
        Supprimer
    </button>

</form>