{% extends 'base.html.twig' %}

{% block title %}Mes Favoris{% endblock %}

{% block body %}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h2 class="section-title mb-1">
            <i class="bi bi-star-fill text-warning"></i>
            Mes Favoris
        </h2>
        <p class="text-muted">Retrouvez ici toutes vos recettes favorites.</p>
    </div>
</div>

{% if recettes is empty %}

    <div class="alert alert-info text-center p-5">
        <h4><i class="bi bi-star"></i> Aucun favori</h4>
        <p>Vous n'avez pas encore ajouté de recettes à vos favoris.</p>
        <a href="{{ path('app_recette_index') }}" class="btn btn-main mt-2">Découvrir les recettes</a>
    </div>

{% else %}

    <div class="row g-4">
        {% for recette in recettes %}
            <div class="col-md-6 col-lg-4">
                <div class="card recipe-card h-100">
                    {% if recette.imageName %}
                        <img src="{{ asset('uploads/recettes/' ~ recette.imageName) }}"
                             class="card-img-top"
                             alt="{{ recette.titre }}"
                             style="height: 220px; object-fit: cover;">
                    {% else %}
                        <div class="d-flex align-items-center justify-content-center bg-light"
                             style="height: 220px; font-size: 4rem;">
                            {{ recette.categorie.icone ?: '🍽' }}
                        </div>
                    {% endif %}

                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge badge-difficulty">{{ difficulty_stars(recette.difficulte) }}</span>
                            <small class="recipe-meta">
                                <i class="bi bi-clock"></i> {{ recette.tempsPreparation|cooking_time_format }}
                            </small>
                        </div>

                        <h5 class="recipe-title">{{ recette.titre }}</h5>

                        <div class="mb-1">
                            <small class="text-muted">
                                {{ recette.categorie.icone ?: '📂' }} {{ recette.categorie.nom }}
                            </small>
                        </div>

                        {% if recette.tags is not empty %}
                            <div class="mb-2 d-flex flex-wrap gap-1">
                                {% for tag in recette.tags %}
                                    <span class="badge" style="background-color: {{ tag.couleur }}; color: #fff;">
                                        {{ tag.nom }}
                                    </span>
                                {% endfor %}
                            </div>
                        {% endif %}

                        <p class="text-muted small">{{ recette.description|slice(0, 100) }}...</p>

                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <small class="recipe-meta">
                                    <i class="bi bi-clock-history"></i> {{ recette.dateCreation|time_ago }}
                                </small>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                            <a href="{{ path('app_recette_show', {'id': recette.id}) }}" class="btn btn-sm btn-dark">
                                Voir
                            </a>
                            <form method="post" action="{{ path('app_favorite_remove', {'recetteId': recette.id}) }}" style="display:inline-block">
                                <button class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Retirer
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

{% endif %}

{{ knp_pagination_render(recettes) }}

{% endblock %}
