{% extends 'base.html.twig' %}

{% block title %}Mes Favoris{% endblock %}

{% block body %}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h2 class="section-title mb-1">
            <i class="bi bi-star-fill text-warning"></i>
            Mes Favoris
        </h2>
        <p class="text-muted">
            Retrouvez ici toutes vos recettes favorites.
        </p>
    </div>
</div>

{% if recettes is empty %}

    <div class="alert alert-info text-center p-5">
        <h4><i class="bi bi-star"></i> Aucun favori</h4>
        <p>Vous n'avez pas encore ajouté de recettes à vos favoris.</p>
        <a href="{{ path('app_recette_index') }}" class="btn btn-main mt-2">
            Découvrir les recettes
        </a>
    </div>

{% else %}

    <div class="row g-4">

        {% for recette in recettes %}

            <div class="col-md-6 col-lg-4">

                <div class="card recipe-card h-100">

                    <img
                        src="{{ recette.imageName ? asset('uploads/recettes/' ~ recette.imageName) : 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?q=80&w=1000' }}"
                        class="card-img-top"
                        alt="{{ recette.titre }}"
                        style="height: 220px; object-fit: cover;"
                    >

                    <div class="card-body d-flex flex-column">

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge badge-difficulty">
                                {{ recette.difficulte }}
                            </span>
                            <small class="recipe-meta">
                                <i class="bi bi-clock"></i>
                                {{ recette.tempsPreparation }} min
                            </small>
                        </div>

                        <h5 class="recipe-title">{{ recette.titre }}</h5>

                        <p class="text-muted small">
                            {{ recette.description|slice(0, 100) }}...
                        </p>

                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <a href="{{ path('app_recette_show', {'id': recette.id}) }}"
                               class="btn btn-sm btn-dark">
                                Voir
                            </a>

                            <form method="post"
                                  action="{{ path('app_favorite_remove', {'id': recette.id}) }}"
                                  style="display:inline-block">
                                <button class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Retirer
                                </button>
                            </form>
                        </div>

                    </div>

                </div>

            </div>

        {% endfor %}

    </div>

{% endif %}

{% endblock %}
